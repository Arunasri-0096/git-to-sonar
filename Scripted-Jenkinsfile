node {
    def mvnPath
    
    stage('git clone process') {
        git 'https://'https://github.com/Arunasri-0096/git-to-sonar.git'
    }
    
    stage('Maven build'){
        def mvnHome = tool name:'maven', type:"maven";
        mvnPath = "${mvnHome}/bin/mvn";
        sh "${mvnPath} clean package"
    }    
}
